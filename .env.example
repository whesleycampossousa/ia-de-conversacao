# Copy to .env and fill with real values.

# Core AI providers
GOOGLE_API_KEY=your_google_api_key_here
# Qwen online (DashScope/Model Studio). Recommended for TTS + cloned voices.
QWEN_API_KEY=
GROQ_API_KEY=
DEEPGRAM_API_KEY=

# Gemini model settings
GEMINI_MODEL_NAME=gemini-3-flash-preview
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
GEMINI_THINKING_BUDGET=0
LEARNING_CORRECTION_KIND_ENABLED=true

# Session/auth
SESSION_SECRET=replace_with_a_long_random_secret
# Admin login is enabled only when BOTH values below are set.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password

# CORS (comma separated)
ALLOWED_ORIGINS=http://localhost:8912,http://localhost:3000,https://your-vercel-domain.vercel.app

# Access/policy toggles
ALLOW_GUEST=0
REQUIRE_WEEKEND_ONLY=0
MAINTENANCE_MODE=0

# Weekend usage window
WEEKEND_LIMIT_SECONDS=10800
USAGE_TZ_OFFSET_HOURS=0
TEMP_GLOBAL_UNLOCK_ENABLED=0
TEMP_GLOBAL_UNLOCK_UNTIL_UTC=

# Context + generation limits
CONTEXT_HISTORY_MESSAGES=12
CONTEXT_CHECK_INTERVAL_SEC=5
MAX_OUTPUT_TOKENS_LEARNING=320
MAX_OUTPUT_TOKENS_SIMULATOR=520
MAX_OUTPUT_TOKENS_GUIDED=240
MAX_OUTPUT_TOKENS_SUGGESTIONS=220
MAX_OUTPUT_TOKENS_REPORT=1800

# Analytics persistence
WEEKLY_ANALYTICS_RETENTION_DAYS=120
WEEKLY_ANALYTICS_FLUSH_INTERVAL_SEC=30

# Rate limiting
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60

# Optional cache/tooling
CACHE_DIR=
# Qwen online TTS config
QWEN_TTS_ENDPOINT=https://dashscope-intl.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
QWEN_TTS_MODEL=qwen3-tts-flash
QWEN_TTS_CLONE_MODEL=qwen3-tts-vc-2026-01-22
QWEN_TTS_VOICE=Cherry
# If you already created a cloud cloned voice, set it here
# Ex.: Clone 16 YouTube Voice (Qwen3-TTS Voice Clone)
QWEN_TTS_CLONE_VOICE=
QWEN_TTS_CLONE_PREFIX=clone16
QWEN_TTS_TIMEOUT_SEC=30
# Optional local fallback server (OpenAI-compatible local TTS)
QWEN_TTS_URL=
GOOGLE_SERVICE_ACCOUNT_JSON=
